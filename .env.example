# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Clave service_role solo en el servidor (Edge Functions / backend), nunca en el navegador.
SUPABASE_ANON_KEY=your_anon_key

# Frontend: copia config.example.js → config.js (no uses .env en esta versión estática).